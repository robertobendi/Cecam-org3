{% extends '@theme/layout.twig' %}

{% set title = entry.field('title') %}
{% set type  = entry.field('event_type') %}
{% set start = entry.field('start_date') %}
{% set end   = entry.field('end_date') %}
{% set location = entry.field('location') %}
{% set organizers = entry.field('organizers') %}
{% set summary = entry.field('summary') %}
{% set external = entry.field('external_url') %}

{% block title %}{{ title }} · CECAM Program{% endblock %}
{% set meta_description = summary %}

{% block content %}

<section class="event-hero">
    <div class="container">
        <p class="event-hero__crumbs small-meta">
            <a href="/program">Program</a>
            <span class="event-row__sep">·</span>
            <span>{{ type|capitalize }}</span>
        </p>
        <p class="eyebrow event-hero__type">{{ type }}</p>
        <h1 class="display event-hero__title">{{ title }}</h1>
        {% if summary %}
            <p class="event-hero__summary">{{ summary }}</p>
        {% endif %}

        <div class="event-hero__facts">
            {% if start and end %}
                <div>
                    <p class="eyebrow">Dates</p>
                    <p class="event-hero__factvalue">{{ start|date('j M') }} – {{ end|date('j M Y') }}</p>
                </div>
            {% endif %}
            {% if location %}
                <div>
                    <p class="eyebrow">Location</p>
                    <p class="event-hero__factvalue">{{ location }}</p>
                </div>
            {% endif %}
            {% if organizers %}
                <div>
                    <p class="eyebrow">Organizers</p>
                    <p class="event-hero__factvalue">{{ organizers }}</p>
                </div>
            {% endif %}
        </div>
    </div>
</section>

<section class="section section--lg">
    <div class="container event-body__grid">
        <aside class="event-body__rail">
            <p class="eyebrow">Event detail</p>
            <p class="small-meta">
                CECAM events are open to academic researchers across Europe and beyond.
                Registration links and the full programme appear on the official event page
                once finalised by the organisers.
            </p>
            {% if external %}
                <a class="btn btn--primary event-body__cta" href="{{ external }}" rel="noopener" target="_blank">Open the full event page →</a>
            {% endif %}
            <a class="btn btn--secondary event-body__cta" href="/program">All events</a>
        </aside>
        <article class="event-body__prose prose">
            {% if entry.field('body') %}
                {{ entry.field('body')|markdown }}
            {% else %}
                <p>{{ summary }}</p>
            {% endif %}
        </article>
    </div>
</section>

<style>
    .event-hero {
        padding-block: clamp(3rem, 6vw, 6rem) clamp(2.5rem, 5vw, 4rem);
        background:
            radial-gradient(ellipse 60% 50% at 100% 0%, rgba(27,58,107,.35) 0, rgba(10,22,40,0) 70%),
            var(--navy);
        border-bottom: 1px solid var(--paper-line);
    }
    .event-hero__crumbs { margin-bottom: 1.5rem; }
    .event-hero__crumbs a { color: var(--paper-mute); border: 0; }
    .event-hero__crumbs a:hover { color: var(--brass); }
    .event-hero__type { color: var(--brass); margin-bottom: 1rem; }
    .event-hero__title {
        max-width: 22ch;
        margin: 0.5rem 0 1.5rem;
    }
    .event-hero__summary {
        font-size: clamp(1.0625rem, .5vw + 1rem, 1.3125rem);
        line-height: 1.5;
        max-width: 42em;
        color: var(--paper);
        margin-bottom: 3rem;
        font-family: 'Fraunces', serif;
        font-style: italic;
        font-weight: 400;
    }
    .event-hero__facts {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
        padding-top: 2rem;
        border-top: 1px solid var(--paper-line);
    }
    @media (min-width: 720px) { .event-hero__facts { grid-template-columns: repeat(3, 1fr); gap: 2rem; } }
    .event-hero__factvalue {
        margin: 0.4rem 0 0;
        font-family: 'Fraunces', serif;
        font-weight: 500;
        font-size: 1.125rem;
        color: var(--bone);
        line-height: 1.3;
    }

    .event-body__grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
    }
    @media (min-width: 900px) {
        .event-body__grid { grid-template-columns: 4fr 8fr; gap: 4rem; }
    }
    .event-body__rail { position: sticky; top: 96px; align-self: start; }
    @media (max-width: 900px) { .event-body__rail { position: static; } }
    .event-body__rail .eyebrow { margin-bottom: 0.75rem; }
    .event-body__cta { display: flex; margin-top: 1.25rem; width: 100%; }

    .event-body__prose h2 { font-size: 1.75rem; }
    .event-body__prose h3 { font-size: 1.25rem; }
</style>

{% endblock %}
