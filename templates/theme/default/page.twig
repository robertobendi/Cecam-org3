{% extends '@theme/layout.twig' %}

{% set title = entry.field('title') %}
{% set eyebrow = entry.field('eyebrow') %}
{% set lede = entry.field('lede') %}
{% set hero = entry.field('hero_image') %}
{% set body = entry.field('body') %}
{% set meta_description = entry.field('meta_description') ?: lede %}
{% set slug = entry.slug %}

{% block title %}{{ title }} · CECAM{% endblock %}

{% block content %}

{% if slug == 'flagship-call' %}
    {# — Special: Flagship Call hero with deadline pull-out — #}
    <section class="flagship-hero" {% if hero %}style="--hero-bg: url('{{ hero }}');"{% endif %}>
        <div class="container flagship-hero__inner">
            {% if eyebrow %}<p class="eyebrow flagship-hero__eyebrow">{{ eyebrow }}</p>{% endif %}
            <h1 class="display flagship-hero__title">{{ title }}</h1>
            {% if lede %}<p class="flagship-hero__lede">{{ lede }}</p>{% endif %}
            <div class="flagship-hero__deadline">
                <p class="eyebrow">Submissions close</p>
                <p class="flagship-hero__date">
                    <span class="flagship-hero__day">17</span>
                    <span class="flagship-hero__month-year">
                        <span>July</span>
                        <span class="meta-mono">2026</span>
                    </span>
                </p>
            </div>
            <div class="flagship-hero__cta">
                <a class="btn btn--primary" href="https://www.cecam.org/submit-flagship-proposal" rel="noopener" target="_blank">Submit your proposal →</a>
                <a class="btn btn--secondary" href="mailto:helpdesk@cecam.org?subject=Flagship%20Call%20question">Email the CECAM team</a>
            </div>
        </div>
    </section>

    <section class="section section--lg">
        <div class="container split-block">
            <div class="split-block__left">
                <p class="eyebrow">The call</p>
                <h2>About the Flagship Call.</h2>
            </div>
            <div class="split-block__right prose">
                {% if body %}{{ body|markdown }}{% endif %}
            </div>
        </div>
    </section>

    <section class="section section--brass">
        <div class="container submit-band">
            <div>
                <p class="eyebrow">Ready</p>
                <h2 class="submit-band__title">Help shape the 2027 – 2028 program.</h2>
            </div>
            <a class="btn" href="https://www.cecam.org/submit-flagship-proposal" rel="noopener" target="_blank" style="background:var(--navy);color:var(--bone);border-color:var(--navy);">Submit a proposal →</a>
        </div>
    </section>

{% elseif slug == 'about' %}
    {# — Special: About — institutional bone-and-navy treatment — #}
    <section class="section section--lg about-title">
        <div class="container">
            {% if eyebrow %}<p class="eyebrow">{{ eyebrow }}</p>{% endif %}
            <h1 class="display about-title__name">
                Centre Européen<br>
                de Calcul Atomique<br>
                <em>et Moléculaire.</em>
            </h1>
            {% if lede %}<p class="about-title__lede">{{ lede }}</p>{% endif %}
        </div>
    </section>

    <section class="section section--bone">
        <div class="container">
            <div class="about-mission prose read-col" style="margin-inline:auto;">
                {% if body %}{{ body|markdown }}{% endif %}
            </div>
        </div>
    </section>

    {% if hero %}
        <section class="section section--lg">
            <div class="container split-block">
                <div class="split-block__left">
                    <p class="eyebrow">Headquarters</p>
                    <h2>EPFL · Lausanne.</h2>
                    <address class="about-address">
                        EPFL CECAM<br>
                        Avenue de Forel 3<br>
                        BCH 3103<br>
                        1015 Lausanne<br>
                        Switzerland
                    </address>
                    <p><a href="mailto:helpdesk@cecam.org">helpdesk@cecam.org</a></p>
                </div>
                <figure class="about-photo">
                    <img src="{{ hero }}" alt="Aerial view of the EPFL campus on the shores of Lake Geneva, with the Alps in the background.">
                    <figcaption class="hero__caption">EPFL · Lake Geneva · Lausanne</figcaption>
                </figure>
            </div>
        </div>
    </section>
    {% endif %}

    <section class="section section--navy-2">
        <div class="container">
            <header class="block-head">
                <div>
                    <p class="eyebrow">Network</p>
                    <h2>A pan-European research consortium.</h2>
                </div>
            </header>
            <ul class="nodes-list">
                <li>CECAM-HQ · EPFL Lausanne</li>
                <li>CECAM-DE-MM1 · Mainz</li>
                <li>CECAM-DE-JUELICH · Jülich</li>
                <li>CECAM-FR-RA · Lyon</li>
                <li>CECAM-FR-MOSER · Grenoble</li>
                <li>CECAM-UK-DARESBURY · STFC</li>
                <li>CECAM-IT-SIMUL · Rome</li>
                <li>CECAM-ES · Zaragoza</li>
                <li>CECAM-NL · Amsterdam</li>
                <li>CECAM-IL · Tel Aviv</li>
                <li>CECAM-AT · Vienna</li>
                <li>CECAM-BE · Brussels</li>
                <li>CECAM-CH · Lugano</li>
                <li>CECAM-FI · Helsinki</li>
                <li>CECAM-PL · Warsaw</li>
                <li>CECAM-PT · Coimbra</li>
                <li>CECAM-SE · Linköping</li>
                <li>CECAM-SI · Ljubljana</li>
                <li>CECAM-IE · Dublin</li>
                <li>CECAM-DK · Copenhagen</li>
                <li>CECAM-GR · Athens</li>
                <li>CECAM-CZ · Prague</li>
            </ul>
        </div>
    </section>

    <section class="section section--brass">
        <div class="container submit-band">
            <div>
                <p class="eyebrow">Stay in touch</p>
                <h2 class="submit-band__title">Mailing list, helpdesk, mailing address.</h2>
            </div>
            <div class="submit-band__actions">
                <a class="btn" href="https://www.cecam.org/register-our-mailing-list" rel="noopener" target="_blank" style="background:var(--navy);color:var(--bone);border-color:var(--navy);">Mailing-list signup</a>
                <a class="btn" href="mailto:helpdesk@cecam.org" style="background:transparent;color:var(--navy);border-color:var(--navy);">helpdesk@cecam.org</a>
            </div>
        </div>
    </section>

{% else %}
    {# — Generic page — #}
    <section class="section section--lg page-hero">
        <div class="container">
            {% if eyebrow %}<p class="eyebrow">{{ eyebrow }}</p>{% endif %}
            <h1 class="display page-hero__title">{{ title }}</h1>
            {% if lede %}<p class="page-hero__lede">{{ lede }}</p>{% endif %}
        </div>
    </section>

    {% if hero %}
        <figure class="page-hero__image">
            <div class="container">
                <img src="{{ hero }}" alt="{{ title }}">
            </div>
        </figure>
    {% endif %}

    <section class="section">
        <div class="container">
            <div class="prose read-col" style="margin-inline:auto;">
                {% if body %}{{ body|markdown }}{% else %}<p>{{ lede }}</p>{% endif %}
            </div>
        </div>
    </section>
{% endif %}

<style>
    /* — Flagship hero — */
    .flagship-hero {
        position: relative;
        padding-block: clamp(4rem, 8vw, 8rem);
        background:
            linear-gradient(to bottom, rgba(10,22,40,.78) 0%, rgba(10,22,40,.92) 100%),
            var(--hero-bg, none) center / cover no-repeat,
            var(--navy);
        overflow: hidden;
        border-bottom: 1px solid var(--paper-line);
    }
    .flagship-hero::after {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 60% 50% at 50% 100%, rgba(27,58,107,.5) 0%, rgba(10,22,40,0) 65%);
        pointer-events: none;
    }
    .flagship-hero__inner {
        position: relative;
        z-index: 1;
        max-width: 980px;
        margin: 0 auto;
        text-align: center;
    }
    .flagship-hero__eyebrow { color: var(--brass); margin-bottom: 1.5rem; }
    .flagship-hero__title {
        margin: 0 auto;
        max-width: 18ch;
        font-size: clamp(2.5rem, 5vw + 1rem, 5rem);
        color: var(--bone);
    }
    .flagship-hero__lede {
        max-width: 38em;
        margin: 1.5rem auto 2.5rem;
        font-size: clamp(1.0625rem, .6vw + 1rem, 1.25rem);
        line-height: 1.55;
        color: var(--paper);
    }
    .flagship-hero__deadline {
        display: inline-flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        padding: 1.5rem 2rem;
        margin: 0 auto 2.5rem;
        border: 1px solid var(--brass);
        background: rgba(10,22,40,.5);
    }
    .flagship-hero__deadline .eyebrow { color: var(--brass); }
    .flagship-hero__date {
        margin: 0;
        display: flex;
        gap: 1rem;
        align-items: baseline;
    }
    .flagship-hero__day {
        font-family: 'Fraunces', serif;
        font-weight: 600;
        font-size: clamp(4rem, 8vw, 7rem);
        line-height: 0.85;
        color: var(--brass);
        font-variation-settings: "opsz" 144;
        letter-spacing: -0.02em;
    }
    .flagship-hero__month-year {
        display: inline-flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.35rem;
    }
    .flagship-hero__month-year > span:first-child {
        font-family: 'Fraunces', serif;
        font-weight: 500;
        font-size: 1.5rem;
        color: var(--bone);
        line-height: 1;
    }
    .flagship-hero__cta {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        justify-content: center;
    }

    /* — Submit band — */
    .submit-band {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
        flex-wrap: wrap;
        padding-block: clamp(2rem, 4vw, 3.5rem);
    }
    .submit-band__title { max-width: 18ch; margin-top: .5rem; }
    .submit-band__actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

    /* — About — */
    .about-title { padding-block: clamp(4rem, 8vw, 8rem) clamp(3rem, 5vw, 5rem); border-bottom: 1px solid var(--paper-line); background: var(--navy); }
    .about-title__name {
        font-size: clamp(2.5rem, 6vw, 5rem);
        line-height: 1.05;
        max-width: 18ch;
        margin-top: 1.5rem;
    }
    .about-title__name em { color: var(--brass); font-weight: 500; }
    .about-title__lede {
        font-family: 'Fraunces', serif;
        font-style: italic;
        font-size: clamp(1.25rem, 1vw + 1rem, 1.625rem);
        line-height: 1.4;
        color: var(--paper);
        max-width: 32em;
        margin-top: 2.5rem;
    }
    .about-mission { font-size: 1.125rem; line-height: 1.7; color: #1A1816; }
    .about-mission p { color: #1A1816; }
    .about-mission p:first-child::first-letter {
        font-family: 'Fraunces', serif;
        font-weight: 600;
        font-size: 4.5rem;
        line-height: 0.85;
        float: left;
        padding: 0.35rem 0.75rem 0 0;
        color: #1B3A6B;
    }
    .about-photo {
        margin: 0;
        position: relative;
        overflow: hidden;
        border: 1px solid var(--paper-line);
        aspect-ratio: 4 / 3;
    }
    .about-photo img { width: 100%; height: 100%; object-fit: cover; }
    .about-address { font-style: normal; line-height: 1.7; color: var(--paper); margin: 1rem 0; }

    .nodes-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 0;
        border: 1px solid var(--paper-line);
    }
    .nodes-list li {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8125rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--paper);
        padding: 1rem 1.25rem;
        border-right: 1px solid var(--paper-line);
        border-bottom: 1px solid var(--paper-line);
    }
    .nodes-list li:nth-child(4n) { border-right: 0; }

    /* — Generic page — */
    .page-hero { padding-block: clamp(4rem, 8vw, 7rem) clamp(2rem, 4vw, 3rem); border-bottom: 1px solid var(--paper-line); background: var(--navy); }
    .page-hero__title { max-width: 16ch; margin-top: 1rem; }
    .page-hero__lede {
        font-family: 'Fraunces', serif;
        font-style: italic;
        font-size: clamp(1.125rem, .7vw + 1rem, 1.5rem);
        line-height: 1.45;
        color: var(--paper);
        margin-top: 2rem;
        max-width: 36em;
    }
    .page-hero__image { margin: 0; }
    .page-hero__image img {
        width: 100%;
        aspect-ratio: 16 / 9;
        object-fit: cover;
        border-block: 1px solid var(--paper-line);
    }
</style>

{% endblock %}
