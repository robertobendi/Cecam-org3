{% extends '@theme/layout.twig' %}

{% block title %}Program 2026–2027 · CECAM{% endblock %}
{% set meta_description = 'The full calendar of CECAM workshops, schools, conferences and events for 2026 and 2027 — from atomistic materials to biological simulation.' %}

{% set type_labels = {
    'workshop':   'Workshops',
    'school':     'Schools',
    'conference': 'Conferences',
    'event':      'Events'
} %}
{% set type_intros = {
    'workshop':   'Five-day flagship and Lorentz workshops at CECAM nodes across Europe.',
    'school':     'Intensive hands-on schools — code, theory, and practice with method authors.',
    'conference': 'CECAM and joint Psi-k / MARVEL research conferences.',
    'event':      'Discussion meetings, working groups, and short ad-hoc gatherings.'
} %}

{% set grouped = { 'workshop': [], 'school': [], 'conference': [], 'event': [] } %}
{% for ev in entries %}
    {% set t = ev.field('event_type', 'event') %}
    {% if grouped[t] is defined %}
        {% set grouped = grouped|merge({ (t): grouped[t]|merge([ev]) }) %}
    {% endif %}
{% endfor %}

{% block content %}

{# — Page title — #}
<section class="program-title">
    <div class="container program-title__grid">
        <div class="program-title__copy">
            <p class="eyebrow">2026 – 2027</p>
            <h1 class="display">Program.</h1>
            <p class="program-title__lede">
                The full calendar of CECAM workshops, schools and conferences across our European
                network. The 2027 – 2028 program is currently being assembled from the
                <a href="/flagship-call">open Flagship Call</a>.
            </p>
        </div>
        <figure class="program-title__figure">
            <img src="/uploads/lecture-hall.jpg" alt="Mathematics lecture at a university auditorium — multiple blackboards filled with handwritten matrix algebra.">
            <figcaption class="hero__caption">Method · Theory · Practice</figcaption>
        </figure>
    </div>
    <div class="container">
        <nav class="program-jump" aria-label="Jump to section">
            {% for key, label in type_labels %}
                <a href="#{{ key }}s" class="program-jump__item">
                    <span class="program-jump__count">{{ grouped[key]|length }}</span>
                    <span class="program-jump__label">{{ label }}</span>
                </a>
            {% endfor %}
        </nav>
    </div>
</section>

{% for key, label in type_labels %}
    <section class="section program-group" id="{{ key }}s">
        <div class="container program-group__inner">
            <aside class="program-group__rail" aria-hidden="true">
                <div class="program-group__count">
                    <span class="program-group__count-n">{{ grouped[key]|length|number_format(0, '.', '') }}</span>
                    <span class="program-group__count-divider">/</span>
                    <span class="program-group__count-label">{{ label }}</span>
                </div>
                <p class="small-meta program-group__intro">{{ type_intros[key] }}</p>
            </aside>
            <div class="program-group__list">
                <header class="program-group__head">
                    <h2>{{ label }}</h2>
                </header>
                {% if grouped[key]|length == 0 %}
                    <p class="program-group__empty">
                        No {{ label|lower }} on the current calendar — the 2027 – 2028 selection
                        will publish here after the Flagship Call closes.
                    </p>
                {% else %}
                    <ol class="event-list">
                        {% for ev in grouped[key] %}
                            {% set start = ev.field('start_date') %}
                            {% set end   = ev.field('end_date') %}
                            <li>
                                <a class="event-row" href="/program/{{ ev.slug }}">
                                    <div class="event-row__date">
                                        {% if start %}
                                            <span class="event-row__day">{{ start|date('d') }}</span>
                                            <span class="event-row__month">{{ start|date('M') }}</span>
                                            <span class="event-row__year">{{ start|date('Y') }}</span>
                                        {% endif %}
                                    </div>
                                    <div class="event-row__body">
                                        <p class="eyebrow event-row__type">{{ ev.field('event_type') }}</p>
                                        <h3>{{ ev.field('title') }}</h3>
                                        <p class="event-row__summary">{{ ev.field('summary') }}</p>
                                        <p class="small-meta">
                                            <span class="event-row__loc">{{ ev.field('location') }}</span>
                                            {% if ev.field('organizers') %}
                                                <span class="event-row__sep">·</span>
                                                <span>{{ ev.field('organizers') }}</span>
                                            {% endif %}
                                        </p>
                                    </div>
                                    <div class="event-row__range meta-mono">
                                        {% if start and end %}
                                            {{ start|date('j M') }} – {{ end|date('j M Y') }}
                                        {% endif %}
                                    </div>
                                </a>
                            </li>
                        {% endfor %}
                    </ol>
                {% endif %}
            </div>
        </div>
    </section>
{% endfor %}

<section class="section section--bone">
    <div class="container split-block">
        <div class="split-block__left">
            <p class="eyebrow">Flagship Call</p>
            <h2>Propose the next workshop.</h2>
        </div>
        <div class="split-block__right">
            <p>
                CECAM's program comes from the community. The 2027 – 2028 Flagship Call solicits
                workshop and school proposals from researchers worldwide, with submissions open
                until <strong>17 July 2026</strong>. Read the call, check the format and timeline,
                and submit through the central CECAM portal.
            </p>
            <p>
                <a class="btn btn--primary" href="/flagship-call" style="background:#1B3A6B;color:#F5F1E8;border-color:#1B3A6B;">Read the Flagship Call</a>
            </p>
        </div>
    </div>
</section>

<style>
    .program-title {
        padding-block: clamp(3.5rem, 7vw, 7rem);
        background:
            radial-gradient(ellipse 70% 60% at 90% 0%, rgba(27,58,107,.4) 0, rgba(10,22,40,0) 60%),
            var(--navy);
        border-bottom: 1px solid var(--paper-line);
    }
    .program-title__grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: clamp(2rem, 4vw, 4rem);
        align-items: end;
    }
    @media (min-width: 960px) {
        .program-title__grid { grid-template-columns: 7fr 5fr; }
    }
    .program-title .display {
        margin-top: 1rem;
        max-width: 12ch;
    }
    .program-title__lede {
        max-width: 38em;
        font-size: clamp(1rem, .6vw + .9rem, 1.1875rem);
        line-height: 1.6;
        color: var(--paper);
        margin-top: 1.5rem;
    }
    .program-title__figure {
        position: relative;
        margin: 0;
        aspect-ratio: 4 / 3;
        overflow: hidden;
        border: 1px solid var(--paper-line);
    }
    .program-title__figure img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: grayscale(.25) brightness(.92) contrast(1.05);
    }
    .program-title__figure::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(225deg, rgba(27,58,107,.35) 0%, rgba(10,22,40,0) 60%);
        pointer-events: none;
    }
    .program-jump {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1px;
        background: var(--paper-line);
        border: 1px solid var(--paper-line);
        margin-top: 3rem;
        max-width: 720px;
    }
    @media (min-width: 720px) { .program-jump { grid-template-columns: repeat(4, 1fr); } }
    .program-jump__item {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        padding: 1.25rem 1.25rem;
        background: var(--navy);
        color: var(--paper);
        border: 0;
        min-height: 88px;
    }
    .program-jump__item:hover { background: var(--navy-3); border: 0; color: var(--bone); }
    .program-jump__count {
        font-family: 'Fraunces', serif;
        font-weight: 600;
        font-size: 2rem;
        line-height: 1;
        color: var(--brass);
        font-variation-settings: "opsz" 144;
    }
    .program-jump__label {
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--paper-soft);
    }

    .program-group { padding-block: clamp(3rem, 5vw, 5rem); border-bottom: 1px solid var(--paper-line); }
    .program-group:last-of-type { border-bottom: 0; }
    .program-group__inner {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
    }
    @media (min-width: 900px) {
        .program-group__inner { grid-template-columns: 4fr 8fr; gap: 3rem; }
    }
    .program-group__rail { position: sticky; top: 96px; align-self: start; }
    @media (max-width: 900px) { .program-group__rail { position: static; } }
    .program-group__count {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
        line-height: 1;
        margin-bottom: 1rem;
    }
    .program-group__count-n {
        font-family: 'Fraunces', serif;
        font-weight: 600;
        font-size: clamp(3.5rem, 6vw, 5.5rem);
        color: var(--brass);
        font-variation-settings: "opsz" 144;
        letter-spacing: -0.02em;
    }
    .program-group__count-divider {
        font-family: 'Fraunces', serif;
        font-weight: 400;
        font-size: 2rem;
        color: var(--paper-line-strong);
    }
    .program-group__count-label {
        font-family: 'Inter', sans-serif;
        font-size: 0.8125rem;
        font-weight: 500;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--paper-soft);
    }
    .program-group__intro { max-width: 24em; }
    .program-group__head { margin-bottom: 1.5rem; }
    .program-group__empty {
        padding: 1.5rem 0;
        color: var(--paper-mute);
        border-top: 1px solid var(--paper-line);
        border-bottom: 1px solid var(--paper-line);
    }

    .event-list { list-style: none; padding: 0; margin: 0; }
    .event-list li { border-top: 1px solid var(--paper-line); }
    .event-list li:last-child { border-bottom: 1px solid var(--paper-line); }
    .event-row {
        display: grid;
        grid-template-columns: 80px 1fr;
        gap: 1.25rem;
        padding: 1.75rem 0;
        align-items: start;
        color: var(--paper);
        border: 0;
        transition: background .15s ease;
    }
    @media (min-width: 720px) {
        .event-row { grid-template-columns: 80px 1fr auto; gap: 2rem; }
    }
    .event-row:hover { background: rgba(232,228,217,.03); border: 0; color: var(--bone); }
    .event-row:hover h3 { color: var(--brass); }
    .event-row__date {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        line-height: 1;
        padding-top: 0.25rem;
    }
    .event-row__day {
        font-family: 'Fraunces', serif;
        font-weight: 600;
        font-size: 2.5rem;
        color: var(--bone);
        line-height: 0.9;
    }
    .event-row__month {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--brass);
        margin-top: 0.35rem;
    }
    .event-row__year {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.6875rem;
        color: var(--paper-mute);
        letter-spacing: 0.08em;
        margin-top: 0.2rem;
    }
    .event-row__type { color: var(--brass); margin-bottom: 0.4rem; }
    .event-row h3 { margin: 0; transition: color .15s ease; max-width: 36ch; }
    .event-row__summary {
        margin: 0.5rem 0 0.75rem;
        max-width: 60ch;
        color: var(--paper-soft);
    }
    .event-row__sep { margin: 0 0.4rem; color: var(--paper-line-strong); }
    .event-row__range {
        white-space: nowrap;
        padding-top: 0.4rem;
        color: var(--paper-mute);
    }
    @media (max-width: 720px) { .event-row__range { display: none; } }
</style>

{% endblock %}
