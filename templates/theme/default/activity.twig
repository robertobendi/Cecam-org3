{% extends '@theme/layout.twig' %}

{% set title = entry.field('title') %}
{% set summary = entry.field('summary') %}
{% set body = entry.field('body') %}
{% set ext = entry.field('external_url') %}
{% set mono = entry.field('monogram') ?: title|slice(0, 1) %}

{% block title %}{{ title }} · CECAM{% endblock %}
{% set meta_description = summary %}

{% block content %}

<section class="section section--lg activity-hero">
    <div class="container activity-hero__inner">
        <div class="activity-hero__mono" aria-hidden="true">{{ mono }}</div>
        <p class="eyebrow">Activity series</p>
        <h1 class="display">{{ title }}</h1>
        {% if summary %}<p class="activity-hero__lede">{{ summary }}</p>{% endif %}
        {% if ext %}
            <p>
                <a class="btn btn--primary" href="{{ ext }}" rel="noopener" target="_blank">Open the live series page →</a>
            </p>
        {% endif %}
    </div>
</section>

<section class="section section--lg">
    <div class="container">
        <article class="prose read-col" style="margin-inline:auto;">
            {% if body %}{{ body|markdown }}{% else %}<p>{{ summary }}</p>{% endif %}
        </article>
    </div>
</section>

<section class="section section--bone">
    <div class="container submit-band">
        <div>
            <p class="eyebrow">More series</p>
            <h2 class="submit-band__title">Explore the other CECAM activities.</h2>
        </div>
        <a class="btn" href="/activities" style="background:#1B3A6B;color:var(--bone);border-color:#1B3A6B;">All activity series →</a>
    </div>
</section>

<style>
    .activity-hero {
        background: var(--navy);
        border-bottom: 1px solid var(--paper-line);
        padding-block: clamp(4rem, 7vw, 7rem);
    }
    .activity-hero__inner { max-width: 42rem; }
    .activity-hero__mono {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 72px;
        height: 72px;
        border: 1px solid var(--brass);
        color: var(--brass);
        font-family: 'Fraunces', serif;
        font-weight: 600;
        font-size: 2rem;
        margin-bottom: 1.5rem;
        font-variation-settings: "opsz" 144;
    }
    .activity-hero h1 { margin: 1rem 0 1.5rem; max-width: 14ch; }
    .activity-hero__lede {
        font-family: 'Fraunces', serif;
        font-style: italic;
        font-size: clamp(1.125rem, .7vw + 1rem, 1.4375rem);
        line-height: 1.45;
        color: var(--paper);
        margin-bottom: 2rem;
    }
</style>

{% endblock %}
