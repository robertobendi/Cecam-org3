{% extends '@theme/layout.twig' %}

{% block title %}{{ ok ? 'Thanks' : 'Try again' }} · CECAM{% endblock %}

{% block content %}
<section class="section section--lg">
    <div class="container" style="max-width:42rem;">
        {% if ok %}
            <p class="eyebrow">Received</p>
            <h1 class="display">Thanks for getting in touch.</h1>
            <p class="page-hero__lede">The CECAM helpdesk will reply within a few working days.</p>
        {% else %}
            <p class="eyebrow">Try again</p>
            <h1 class="display">Something went wrong.</h1>
            <ul class="prose">
                {% for e in errors %}<li>{{ e }}</li>{% endfor %}
            </ul>
            <p style="margin-top:2rem;"><a class="btn btn--secondary" href="javascript:history.back()">← Go back</a></p>
        {% endif %}
    </div>
</section>
{% endblock %}
